# Azure OpenAI credentials (required)
# In production, fetch from Azure Key Vault using azure-identity + SecretClient;
# see Key Vault "open-ai-keys-rob", secret "open-ai-key-rob".
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://open-ai-resource-rob.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Deployment names (required — these are Azure deployment names, not model names)
AZURE_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_EMBEDDING_API_VERSION=2023-05-15

# API shared-secret for /query (optional; if unset, /query is open with a startup warning)
API_KEY=

# Pipeline knobs (optional — defaults in src/config.py)
# CHUNK_SIZE=800
# CHUNK_OVERLAP=100
# TOP_K=5
# RETRIEVE_K=10
